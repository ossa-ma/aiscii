{
  "name": "aiscii",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "aiscii": "./cli.ts"
  },
  "files": [
    "src/",
    "cli.ts",
    "skill.md",
    "server.ts",
    "templates/"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./modules/*": "./src/modules/*.ts"
  },
  "scripts": {
    "dev": "bun run server.ts",
    "build": "bun build src/index.ts --outdir dist --target browser --sourcemap --minify",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
